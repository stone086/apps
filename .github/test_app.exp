#!/usr/bin/expect -f

set timeout 900
set app [lindex $argv 0]

if {$app == ""} {
    send_user "Usage: ./test_app.exp <app_id>\n"
    exit 1
}

send_user "\n>>> Testing: $app <<<\n"
spawn bash -c "curl -sL kejilion.sh | bash -s app $app"

expect "请输入编号" { send "$app\r" }

# 依次执行: 4(状态), 1(安装), 3(更新), 2(卸载)
foreach op {4 1 3 2} {
    expect "1. 安装应用" { send "$op\r" }
    expect {
        "y/n" { send "y\r"; exp_continue }
        "确认" { send "y\r"; exp_continue }
        "请输入" { send "\r"; exp_continue }
        "端口" { send "\r"; exp_continue }
        "按任意键" { send "\r"; exp_continue }
        "1. 安装应用" { }
    }
}

expect "1. 安装应用" { send "0\r" }
expect "返回主菜单" { send "0\r" }
expect eof
